    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/highlight.min.js"></script>
    <script src="https://cdn.jsdelivr.net/gh/highlightjs/cdn-release@11.9.0/build/languages/php.min.js"></script>
    <script>
    (function() {
        // Exception chain data for header and arguments updates
        const exceptionChain = <?= json_encode(array_map(function ($exc) {
            return [
                    'index' => $exc['index'],
                    'class' => $exc['class'],
                    'shortClass' => $exc['shortClass'],
                    'message' => $exc['message'],
                    'code' => $exc['code'],
                    'file' => $exc['file'],
                    'shortFile' => $exc['shortFile'],
                    'line' => $exc['line'],
                    'arguments' => $exc['arguments'],
            ];
        }, $exceptionChain), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_HEX_AMP) ?>;

        let currentExceptionIndex = 0;

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        // Update header with exception info
        function updateHeader(excIndex) {
            const exc = exceptionChain[excIndex];
            if (!exc) return;
            
            currentExceptionIndex = excIndex;
            
            // Update type
            const typeEl = document.getElementById('exc-type');
            if (typeEl) {
                typeEl.innerHTML = escapeHtml(exc.class) + 
                    (exc.code ? ' <span class="exception-code">(' + escapeHtml(String(exc.code)) + ')</span>' : '');
            }
            
            // Update message
            const msgEl = document.getElementById('exc-message');
            if (msgEl) {
                msgEl.textContent = exc.message;
            }
            
            // Update location
            const locEl = document.getElementById('exc-location');
            if (locEl) {
                locEl.textContent = exc.shortFile + ':' + exc.line;
            }
            
            // Update arguments panel
            updateArgumentsPanel(exc);
            
            // Update search buttons
            updateSearchButtons(exc);
        }
        
        // Update arguments panel content
        function updateArgumentsPanel(exc) {
            const panel = document.getElementById('args-panel');
            if (!panel) return;
            
            if (exc.arguments && Object.keys(exc.arguments).length > 0) {
                let html = '<table class="args-table">';
                html += '<thead><tr><td class="arg-index">#</td><td class="arg-name">Name</td><td class="arg-type">Type</td><td class="arg-value">Value</td></tr></thead>';
                html += '<tbody>';
                let idx = 0;
                for (const name in exc.arguments) {
                    const arg = exc.arguments[name];
                    html += '<tr>';
                    html += '<td class="arg-index">' + idx + '</td>';
                    html += '<td class="arg-name">$' + escapeHtml(name) + '</td>';
                    html += '<td class="arg-type">' + escapeHtml(arg.type) + '</td>';
                    html += '<td class="arg-value">' + escapeHtml(arg.value) + '</td>';
                    html += '</tr>';
                    idx++;
                }
                html += '</tbody></table>';
                panel.innerHTML = html;
            } else {
                panel.innerHTML = '<div class="empty-state"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-variable"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4c-2.5 5 -2.5 10 0 16m14 -16c2.5 5 2.5 10 0 16m-10 -11h1c1 0 1 1 2.016 3.527c.984 2.473 .984 3.473 1.984 3.473h1" /><path d="M8 16c1.5 0 3 -2 4 -3.5s2.5 -3.5 4 -3.5" /></svg><p>No custom arguments for this exception</p></div>';
            }
        }
        
        // Update search buttons URLs
        function updateSearchButtons(exc) {
            const query = encodeURIComponent(exc.shortClass + ' ' + exc.message);
            const buttons = document.querySelectorAll('.search-btn');
            buttons.forEach(function(btn) {
                const urlTemplate = btn.getAttribute('data-url-template');
                if (urlTemplate) {
                    btn.setAttribute('href', urlTemplate.replace('%s', query));
                }
            });
        }

        // Highlight all code blocks
        document.querySelectorAll('code.language-php').forEach(function(block) {
            hljs.highlightElement(block);
        });

        // Main tab switching
        document.querySelectorAll('.main-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                const tabId = this.getAttribute('data-tab');
                document.querySelectorAll('.main-tab').forEach(function(t) { t.classList.remove('active'); });
                document.querySelectorAll('.main-content').forEach(function(c) { c.classList.remove('active'); });
                this.classList.add('active');
                const content = document.getElementById('tab-' + tabId);
                if (content) content.classList.add('active');
            });
        });

        // Stack frame switching
        function activateFrame(element) {
            const frameId = element.getAttribute('data-frame');

            // Hide all args
            document.querySelectorAll('.frame-args-list').forEach(function(a) { 
                a.classList.remove('show');
            });
            document.querySelectorAll('.frame-args-toggle .chevron').forEach(function(svg) {
                svg.style.transform = '';
            });
            
            // Switch active frame
            document.querySelectorAll('.stack-frame').forEach(function(f) { 
                f.classList.remove('active'); 
            });
            element.classList.add('active');
            
            // Show args of new active frame
            const args = element.querySelector('.frame-args-list');
            if (args) {
                args.classList.add('show');
                const chevron = element.querySelector('.frame-args-toggle .chevron');
                if (chevron) chevron.style.transform = 'rotate(90deg)';
            }
            
            // Switch code block
            document.querySelectorAll('.code-block').forEach(function(b) { b.classList.remove('active'); });
            const codeBlock = document.querySelector('.code-block[data-frame="' + frameId + '"]');
            if (codeBlock) codeBlock.classList.add('active');
            
            // If this is an exception frame, update header and arguments
            if (element.getAttribute('data-is-exception') === '1') {
                const excIndex = parseInt(element.getAttribute('data-exc-index'), 10);
                updateHeader(excIndex);
            }
        }

        document.querySelectorAll('.stack-frame').forEach(function(frame) {
            frame.addEventListener('click', function(e) {
                // Don't switch if clicking on args toggle
                if (e.target.closest('.frame-args-toggle')) return;
                activateFrame(this);
            });
        });

        // Copy path button
        document.querySelectorAll('.code-action[data-path]').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const path = this.getAttribute('data-path');
                if (navigator.clipboard && path) {
                    navigator.clipboard.writeText(path);
                }
            });
        });

        // Arguments toggle
        document.querySelectorAll('.frame-args-toggle').forEach(function(toggle) {
            toggle.addEventListener('click', function(e) {
                e.stopPropagation();
                const targetId = this.getAttribute('data-toggle');
                const target = document.getElementById(targetId);
                if (target) {
                    target.classList.toggle('show');
                    const chevron = this.querySelector('.chevron');
                    if (chevron) {
                        chevron.style.transform = target.classList.contains('show') ? 'rotate(90deg)' : '';
                    }
                }
            });
        });

        // Show args on first active frame by default
        const activeFrame = document.querySelector('.stack-frame.active');
        if (activeFrame) {
            const args = activeFrame.querySelector('.frame-args-list');
            if (args) {
                args.classList.add('show');
                const chevron = activeFrame.querySelector('.frame-args-toggle .chevron');
                if (chevron) chevron.style.transform = 'rotate(90deg)';
            }
        }
    })();
    </script>
</body>
